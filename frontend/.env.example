# Frontend/server runtime
NODE_ENV=development
VITE_APP_ID=ceph-ai-advanced
JWT_SECRET=replace-with-a-long-random-secret
OWNER_OPEN_ID=
OAUTH_SERVER_URL=http://localhost:3000

# Database
DATABASE_URL=mysql://user:password@localhost:3306/ceph_ai

# Secure object storage via Forge/S3-compatible proxy
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Clinical services
BACKEND_API_BASE_URL=http://localhost:5180
AI_SERVICE_BASE_URL=http://localhost:8000

# Optional browser-facing aliases when needed by Vite code
VITE_BACKEND_API_BASE_URL=http://localhost:5180
VITE_AI_SERVICE_BASE_URL=http://localhost:8000
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
