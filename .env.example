# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ────────────────────────
# Never commit .env to version control!

# JWT (generate a secure 256-bit key)
JWT_SECRET_KEY=REPLACE_WITH_SECURE_256BIT_KEY

# Internal service authentication between .NET API and AI microservice
AI_SERVICE_KEY=REPLACE_WITH_INTERNAL_SERVICE_KEY

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=cephanalysis_db

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# OpenAI (optional, for LLM treatment justification)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Storage (set Provider to Local for dev, S3 or Azure for production)
STORAGE_PROVIDER=Local
STORAGE_LOCAL_BASE_PATH=uploads

# AWS S3 (if STORAGE_PROVIDER=S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1

# Azure Blob (if STORAGE_PROVIDER=Azure)
AZURE_STORAGE_CONNECTION_STRING=

# AI Model
AI_MODEL_PATH=D:\Ai_Ceph_Project\Ai Cephalometric Analysis\ai_service\engine\
AI_MODEL_VERSION=v1.0.0
AI_DEVICE=cpu
