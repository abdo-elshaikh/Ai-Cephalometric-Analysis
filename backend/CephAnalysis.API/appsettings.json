{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cephanalysis_db;Username=postgres;Password=admin"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_SECURE_RS256_KEY_IN_PRODUCTION",
    "Issuer": "CephAnalysis",
    "Audience": "CephAnalysis.Client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000",
    "ServiceKey": "dev-service-key"
  },
  "Storage": {
    "Provider": "Local",
    "LocalBasePath": "uploads",
    "S3BucketName": "",
    "S3Region": "",
    "AzureConnectionString": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "RateLimiting": {
    "RequestsPerMinute": 100,
    "MaxConcurrentAiJobs": 10
  },
  "AllowedHosts": "*"
}